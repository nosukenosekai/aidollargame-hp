{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "language": "japanese",
  "fileCheckpointingEnabled": true,
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git restore *)",
      "Bash(git stash *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git push *)",
      "Bash(git remote -v)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(python3 scripts/generate_ogp.py*)",
      "Bash(python scripts/generate_ogp.py*)"
    ],
    "ask": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(pip install *)",
      "Bash(pip3 install *)",
      "Bash(npm install *)",
      "Bash(npx *)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(*rm -rf*)",
      "Bash(*rm -fr*)",
      "Bash(rmdir *)",
      "Bash(*shred *)",
      "Bash(*truncate *)",
      "Bash(*git clean *)",
      "Bash(*git reset --hard*)",
      "Bash(*git push --force*)",
      "Bash(*git push -f *)",
      "Bash(*find * -delete*)",
      "Bash(*generate_articles.py*)",
      "Bash(*npm publish*)",
      "Bash(*stripe *)",
      "Bash(*aws *)",
      "Bash(*gcloud *)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./**/*credential*)",
      "Read(./**/*secret*)",
      "Read(./**/id_rsa*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)"
    ]
  },
  "autoMode": {
    "hard_deny": [
      "$defaults",
      "ファイルやディレクトリの削除・破壊（rm / rmdir / shred / truncate / git clean / git reset --hard / git push --force / find -delete など）。形を変えても、cdで連結されていても、削除系は一切実行しない。",
      "お金が発生する操作・課金される可能性のあるAPI呼び出しや支払い（例: 有料APIを叩く scripts/generate_articles.py の実行、npm publish、stripe/aws/gcloud などの課金コマンド、決済）。一切実行しない。"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "c=$(jq -r '.tool_input.command // empty'); case \"$c\" in *rm\\ -rf*|*rm\\ -fr*|*git\\ clean*|*git\\ reset\\ --hard*|*git\\ push\\ --force*|*generate_articles.py*) printf '%s' '{\"systemMessage\":\"🚫 削除または課金につながる可能性のある操作です。お金・削除は実行しない方針のため、内容を必ず確認してください。\"}';; esac"
          }
        ]
      }
    ]
  }
}
